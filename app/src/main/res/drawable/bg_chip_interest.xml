<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape>
            <gradient
                android:angle="0"
                android:startColor="@color/chip_checked_start"
                android:endColor="@color/chip_checked_end" />
            <corners android:radius="999dp" />
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="@color/chip_bg" />
            <corners android:radius="999dp" />
            <stroke
                android:width="1dp"
                android:color="@color/chip_stroke" />
        </shape>
    </item>
</selector>